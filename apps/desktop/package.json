{
  "name": "@pwrsnap/desktop",
  "productName": "PwrSnap",
  "version": "0.0.1-alpha.0",
  "private": true,
  "description": "Mac-first agentic screen capture tool",
  "author": "PwrDrvr LLC",
  "license": "UNLICENSED",
  "copyright": "Copyright © 2026 PwrDrvr LLC. All rights reserved.",
  "type": "module",
  "main": "out/main/index.js",
  "scripts": {
    "build": "electron-vite build",
    "dev": "electron-vite dev",
    "package:dryrun": "node ./scripts/release.mjs --dryrun",
    "package": "node ./scripts/release.mjs --no-publish",
    "release": "node ./scripts/release.mjs",
    "postinstall": "electron-builder install-app-deps",
    "preview": "electron-vite preview",
    "pretest:e2e": "pnpm build",
    "test:e2e": "playwright test -c playwright.config.ts",
    "tray-icon": "node ./scripts/generate-tray-icon.mjs",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@fontsource/geist-mono": "^5.2.5",
    "@fontsource/geist-sans": "^5.2.5",
    "@pwrsnap/codex-app-server-protocol": "workspace:*",
    "@pwrsnap/shared": "workspace:*",
    "better-sqlite3": "^12.6.0",
    "electron-log": "^5.4.3",
    "nanoid": "^5.0.9",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "safe-stable-stringify": "^2.5.0",
    "sharp": "^0.34.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@playwright/test": "^1.50.0",
    "@vitejs/plugin-react": "^5.2.0",
    "electron": "^41.2.1",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "vite": "^7.3.2"
  }
}
