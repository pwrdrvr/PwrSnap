node_modules/
.pnpm-store/

# ---- Build output ----
out/
dist/
dist-electron/
.vite/
*.tsbuildinfo

# ---- Compiled native helpers ----
# Swift CLIs that wrap macOS-only system APIs. Compiled by
# apps/desktop/scripts/build-native.mjs at install time. Sources are
# checked in under apps/desktop/native/; the binaries are not.
apps/desktop/build/native/

# ---- Electron-builder output ----
# Signed/notarized DMG + ZIP land here
apps/desktop/dist/
# pnpm deploy stage (a future release.mjs will materialize a flat node_modules tree here)
apps/desktop/release-stage/

# ---- Test / coverage artifacts ----
coverage/
playwright-report/
test-results/

# ---- Logs ----
*.log
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*
yarn-error.log*

