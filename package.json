{
  "name": "pwrsnap-workspace",
  "version": "0.0.1-alpha.0",
  "private": true,
  "description": "Mac-first agentic screen capture tool",
  "author": "PwrDrvr LLC",
  "license": "MIT",
  "copyright": "Copyright © 2026 PwrDrvr LLC",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "preinstall": "node ./scripts/check-node-version.mjs",
    "build": "pnpm --filter @pwrsnap/desktop build",
    "dev": "pnpm --filter @pwrsnap/desktop dev",
    "design": "npx --yes serve design -l 4321",
    "codex:generate-protocol": "pnpm --filter @pwrsnap/codex-app-server-protocol generate",
    "rebuild:electron-native": "pnpm --filter @pwrsnap/desktop rebuild:electron-native",
    "typecheck": "pnpm -r --if-present typecheck",
    "deps:check": "node ./scripts/check-dependency-version-policy.mjs",
    "licenses:check": "node ./scripts/check-package-license-policy.mjs && node ./scripts/generate-third-party-licenses.mjs --check",
    "licenses:generate": "node ./scripts/generate-third-party-licenses.mjs",
    "lint:colors": "node ./scripts/lint-renderer-colors.mjs",
    "lint": "pnpm deps:check && pnpm typecheck && pnpm licenses:check && pnpm lint:colors",
    "test": "vitest run --config vitest.workspace.ts",
    "test:watch": "vitest --config vitest.workspace.ts",
    "test:desktop-e2e": "pnpm --filter @pwrsnap/desktop build && pnpm --filter @pwrsnap/desktop test:e2e",
    "test:desktop-e2e:docker": "./scripts/e2e/run-docker.sh",
    "release:check": "node ./scripts/check-desktop-release-metadata.mjs"
  },
  "devDependencies": {
    "@types/node": "24.12.4",
    "jsdom": "^29.0.2",
    "typescript": "^6.0.2",
    "vitest": "^4.1.7"
  },
  "pnpm": {
    "overrides": {
      "@types/node": "24.12.4",
      "@pwrdrvr/agent-core": "file:/Users/huntharo/pwrdrvr/agent-kit/packages/agent-core",
      "@pwrdrvr/agent-transport": "file:/Users/huntharo/pwrdrvr/agent-kit/packages/agent-transport",
      "@pwrdrvr/codex-discovery": "file:/Users/huntharo/pwrdrvr/agent-kit/packages/codex-discovery",
      "@pwrdrvr/agent-client": "file:/Users/huntharo/pwrdrvr/agent-kit/packages/agent-client",
      "@pwrdrvr/agent-chat-react": "file:/Users/huntharo/pwrdrvr/agent-kit/packages/agent-chat-react"
    }
  }
}
