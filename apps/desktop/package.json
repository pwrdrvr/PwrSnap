{
  "name": "@pwrsnap/desktop",
  "productName": "PwrSnap",
  "version": "1.0.0-beta.18",
  "private": true,
  "description": "Mac-first agentic screen capture tool",
  "author": "PwrDrvr LLC",
  "license": "MIT",
  "copyright": "Copyright © 2026 PwrDrvr LLC",
  "type": "module",
  "main": "out/main/index.js",
  "scripts": {
    "build": "electron-vite build",
    "dev": "node ./scripts/dev.mjs",
    "build:native": "node ./scripts/build-native.mjs",
    "build:ffmpeg": "node ./scripts/build-ffmpeg.mjs",
    "rebuild:electron-native": "node ./scripts/rebuild-native-for-electron.mjs && node ./scripts/build-native.mjs",
    "package:dryrun": "node ./scripts/release.mjs --dryrun",
    "package:skip-notarize": "node ./scripts/release.mjs --no-publish --skip-notarize",
    "package": "node ./scripts/release.mjs --no-publish",
    "package:win": "node ./scripts/package-win.mjs",
    "release": "node ./scripts/release.mjs",
    "postinstall": "pnpm run rebuild:electron-native",
    "preview": "electron-vite preview",
    "pretest:e2e": "node ./scripts/rebuild-native-for-electron.mjs && node ./scripts/build-native.mjs && pnpm build",
    "test:e2e": "playwright test -c playwright.config.ts",
    "generate:dmg-background": "swift ./scripts/generate-dmg-background.swift ./build/dmg-background.png",
    "generate:app-icon": "swift ./scripts/generate-app-icon.swift ./build/icon.iconset && iconutil -c icns build/icon.iconset -o build/icon.icns",
    "verify:asar-contents": "node ./scripts/verify-asar-contents.mjs",
    "tray-icon": "node ./scripts/generate-tray-icon.mjs",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@fontsource/geist-mono": "^5.2.8",
    "@fontsource/geist-sans": "^5.2.5",
    "@modelcontextprotocol/sdk": "1.29.0",
    "@pwrdrvr/agent-acp": "^0.12.2",
    "@pwrdrvr/agent-chat-react": "^0.1.3",
    "@pwrdrvr/agent-client": "^0.6.1",
    "@pwrdrvr/agent-core": "^0.2.0",
    "@pwrdrvr/agent-transport": "^0.1.6",
    "@pwrdrvr/codex-app-server-protocol": "0.133.0",
    "@pwrdrvr/codex-discovery": "^0.1.3",
    "@pwrsnap/shared": "workspace:*",
    "@shutterstock/p-map-iterable": "^1.1.2",
    "@tanstack/react-virtual": "^3.13.24",
    "better-sqlite3": "^12.10.0",
    "electron-log": "^5.4.4",
    "electron-updater": "^6.8.9",
    "nanoid": "^5.0.9",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "safe-stable-stringify": "^2.5.0",
    "sharp": "^0.34.0",
    "transformation-matrix": "^3.1.0",
    "wavesurfer.js": "^7.12.7",
    "yauzl": "^3.3.0",
    "yazl": "^3.3.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@electron/asar": "^4.2.0",
    "@playwright/test": "^1.60.0",
    "@types/archiver": "^7.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@types/yauzl": "^2.10.3",
    "@types/yazl": "^3.3.1",
    "@vitejs/plugin-react": "^5.2.0",
    "archiver": "^7.0.1",
    "electron": "^41.7.1",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "vite": "^7.3.5"
  }
}
